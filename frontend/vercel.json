{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://ai-resume-analyzer.onrender.com/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
